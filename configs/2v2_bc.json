{
  "schema_version": 4,
  "obs_schema_version": 1,
  "env": {
    "mode": "soccar",
    "collision_meshes_path": "collision_meshes",
    "team_size": 2,
    "tick_skip": 8,
    "tick_rate": 120,
    "max_episode_ticks": 2250,
    "no_touch_timeout_seconds": 10.0,
    "spawn_opponents": true,
    "randomize_kickoffs": true,
    "seed": 0
  },
  "outcome": {
    "score": 1.0,
    "concede": -1.0,
    "neutral": 0.0
  },
  "action_table": {
    "builtin": "rlgym_lookup_v1",
    "actions": []
  },
  "model": {
    "observation_dim": 132,
    "action_dim": 90,
    "use_layer_norm": true,
    "encoder_dim": 512,
    "workspace_dim": 512,
    "stm_slots": 48,
    "stm_key_dim": 128,
    "stm_value_dim": 128,
    "ltm_slots": 32,
    "ltm_dim": 128,
    "controller_dim": 512,
    "consolidation_stride": 8,
    "retired_decay": 0.96,
    "value_hidden_dim": 256,
    "value_num_atoms": 51,
    "value_v_min": -10.0,
    "value_v_max": 10.0
  },
  "ppo": {
    "num_envs": 512,
    "collection_workers": 16,
    "init_checkpoint": "",
    "rollout_length": 256,
    "minibatch_size": 65536,
    "update_epochs": 3,
    "clip_range": 0.2,
    "entropy_coef": 0.01,
    "value_coef": 1.0,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "learning_rate": 0.0002,
    "max_grad_norm": 1.0,
    "device": "cuda:0",
    "checkpoint_interval": 10,
    "max_rolling_checkpoints": 5,
    "sequence_length": 16,
    "burn_in": 0,
    "use_adaptive_epsilon": true,
    "adaptive_epsilon_beta": 1.0,
    "epsilon_min": 0.05,
    "epsilon_max": 0.3,
    "use_confidence_weighting": true,
    "confidence_weight_type": "entropy",
    "confidence_weight_delta": 1e-06,
    "normalize_confidence_weights": false
  },
  "offline_dataset": {
    "train_manifest": "data/offline/2v2/train_manifest.json",
    "val_manifest": "data/offline/2v2/val_manifest.json",
    "batch_size": 8192,
    "shuffle": true,
    "seed": 7
  },
  "behavior_cloning": {
    "enabled": true,
    "epochs": 8,
    "sequence_length": 32,
    "learning_rate": 0.0003,
    "weight_decay": 0.000001,
    "label_smoothing": 0.01,
    "max_grad_norm": 1.0
  },
  "self_play_league": {
    "enabled": false,
    "opponent_probability": 0.0,
    "snapshot_interval_updates": 10,
    "max_snapshots": 8,
    "training_opponent_policy": "stochastic",
    "eval_interval_updates": 10,
    "eval_num_envs": 8,
    "eval_matches_per_snapshot": 4,
    "eval_policy": "deterministic",
    "elo_initial": 1000.0,
    "elo_k": 32.0
  },
  "wandb": {
    "enabled": false,
    "project": "pulsar",
    "entity": "",
    "run_name": "",
    "group": "bc",
    "job_type": "bc_pretrain",
    "dir": "",
    "mode": "online",
    "python_executable": "python3",
    "script_path": "scripts/wandb_stream.py",
    "tags": ["offline", "bc", "continuum"]
  }
}
