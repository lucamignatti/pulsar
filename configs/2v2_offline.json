{
  "schema_version": 1,
  "obs_schema_version": 1,
  "env": {
    "mode": "soccar",
    "collision_meshes_path": "collision_meshes",
    "team_size": 2,
    "tick_skip": 8,
    "tick_rate": 120,
    "max_episode_ticks": 2250,
    "no_touch_timeout_seconds": 10.0,
    "spawn_opponents": true,
    "randomize_kickoffs": true,
    "seed": 0
  },
  "action_table": {
    "builtin": "rlgym_lookup_v1"
  },
  "model": {
    "observation_dim": 132,
    "action_dim": 90,
    "use_layer_norm": true,
    "encoder_dim": 512,
    "workspace_dim": 512,
    "stm_slots": 48,
    "stm_key_dim": 128,
    "stm_value_dim": 128,
    "ltm_slots": 32,
    "ltm_dim": 128,
    "controller_dim": 512,
    "consolidation_stride": 8,
    "retired_decay": 0.96
  },
  "ppo": {
    "num_envs": 128,
    "collection_workers": 16,
    "init_checkpoint": "",
    "rollout_length": 256,
    "minibatch_size": 32768,
    "epochs": 3,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_range": 0.2,
    "entropy_coef": 0.01,
    "value_coef": 1.0,
    "learning_rate": 0.0002,
    "max_grad_norm": 1.0,
    "device": "cuda",
    "checkpoint_interval": 10,
    "sequence_length": 16,
    "burn_in": 0,
    "value_v_min": -10.0,
    "value_v_max": 10.0,
    "value_num_atoms": 51,
    "use_adaptive_epsilon": true,
    "adaptive_epsilon_beta": 1.0,
    "epsilon_min": 0.05,
    "epsilon_max": 0.3,
    "use_confidence_weighting": true,
    "confidence_weight_type": "entropy",
    "confidence_weight_delta": 1e-06,
    "normalize_confidence_weights": false
  },
  "offline_dataset": {
    "train_manifest": "data/offline/2v2/train_manifest.json",
    "val_manifest": "data/offline/2v2/val_manifest.json",
    "batch_size": 8192,
    "shuffle": true,
    "seed": 7
  },
  "behavior_cloning": {
    "enabled": true,
    "epochs": 8,
    "learning_rate": 0.0003,
    "weight_decay": 1e-06,
    "label_smoothing": 0.01,
    "max_grad_norm": 1.0,
    "sequence_length": 32
  },
  "next_goal_predictor": {
    "enabled": true,
    "init_checkpoint": "",
    "epochs": 8,
    "learning_rate": 0.0003,
    "weight_decay": 1e-06,
    "label_smoothing": 0.01,
    "max_grad_norm": 1.0,
    "class_weights": [1.0, 1.0, 0.25],
    "reuse_normalizer": true
  },
  "value_pretraining": {
    "enabled": true,
    "epochs": 8,
    "learning_rate": 0.0003,
    "weight_decay": 1e-06,
    "max_grad_norm": 1.0,
    "loss_coef": 1.0,
    "target_sync_interval_epochs": 1,
    "bootstrap_truncated": true
  },
  "offline_optimization": {
    "trunk_learning_rate": 0.0003,
    "trunk_weight_decay": 1e-06,
    "trunk_max_grad_norm": 1.0
  },
  "wandb": {
    "enabled": false,
    "project": "pulsar",
    "entity": "",
    "run_name": "",
    "group": "offline",
    "job_type": "offline_pretrain",
    "dir": "",
    "mode": "online",
    "python_executable": "python3",
    "script_path": "scripts/wandb_stream.py",
    "tags": ["offline", "bc", "critic", "ngp", "continuum"]
  }
}
