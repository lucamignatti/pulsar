{
  "schema_version": 4,
  "obs_schema_version": 1,
  "env": {
    "mode": "soccar",
    "collision_meshes_path": "collision_meshes",
    "team_size": 2,
    "tick_skip": 8,
    "tick_rate": 120,
    "max_episode_ticks": 2250,
    "no_touch_timeout_seconds": 10.0,
    "spawn_opponents": true,
    "randomize_kickoffs": true,
    "seed": 0
  },
  "outcome": {
    "score": 1.0,
    "concede": -1.0,
    "neutral": 0.0
  },
  "action_table": {
    "builtin": "rlgym_lookup_v1",
    "actions": []
  },
  "model": {
    "observation_dim": 132,
    "action_dim": 90,
    "use_layer_norm": true,
    "encoder_dim": 512,
    "workspace_dim": 512,
    "stm_slots": 48,
    "stm_key_dim": 128,
    "stm_value_dim": 128,
    "ltm_slots": 32,
    "ltm_dim": 128,
    "controller_dim": 512,
    "consolidation_stride": 8,
    "retired_decay": 0.96,
    "action_embedding_dim": 64,
    "future_latent_dim": 128,
    "future_horizon_count": 3
  },
  "lfpo": {
    "num_envs": 512,
    "collection_workers": 16,
    "init_checkpoint": "",
    "rollout_length": 256,
    "minibatch_size": 65536,
    "update_epochs": 3,
    "clip_range": 0.2,
    "entropy_coef": 0.01,
    "latent_loss_coef": 1.0,
    "behavior_prior_coef": 0.0,
    "behavior_prior_decay_updates": 0,
    "learning_rate": 0.0002,
    "max_grad_norm": 1.0,
    "device": "cuda:0",
    "checkpoint_interval": 10,
    "max_rolling_checkpoints": 5,
    "sequence_length": 16,
    "burn_in": 0,
    "candidate_count": 8,
    "evaluator_update_interval": 4,
    "evaluator_target_update_interval": 500,
    "evaluator_target_ema_tau": 0.01,
    "online_window_capacity": 64
  },
  "future_evaluator": {
    "horizons": [8, 32, 96],
    "latent_dim": 128,
    "model_dim": 256,
    "layers": 4,
    "heads": 8,
    "feedforward_dim": 1024,
    "dropout": 0.0,
    "outcome_classes": 3,
    "learning_rate": 0.0003,
    "weight_decay": 0.000001,
    "max_grad_norm": 1.0,
    "class_weights": [1.0, 1.0, 0.25]
  },
  "offline_dataset": {
    "train_manifest": "data/offline/2v2/train_manifest.json",
    "val_manifest": "data/offline/2v2/val_manifest.json",
    "batch_size": 8192,
    "shuffle": true,
    "seed": 7
  },
  "offline_pretraining": {
    "evaluator_epochs": 8,
    "actor_epochs": 8,
    "sequence_length": 32,
    "behavior_cloning_learning_rate": 0.0003,
    "actor_learning_rate": 0.0003,
    "evaluator_learning_rate": 0.0003,
    "weight_decay": 0.000001,
    "label_smoothing": 0.01,
    "behavior_cloning_loss_coef": 1.0,
    "latent_loss_coef": 1.0,
    "max_grad_norm": 1.0
  },
  "self_play_league": {
    "enabled": false,
    "opponent_probability": 0.0,
    "snapshot_interval_updates": 10,
    "max_snapshots": 8,
    "training_opponent_policy": "stochastic",
    "eval_interval_updates": 10,
    "eval_num_envs": 8,
    "eval_matches_per_snapshot": 4,
    "eval_policy": "deterministic",
    "elo_initial": 1000.0,
    "elo_k": 32.0
  },
  "wandb": {
    "enabled": false,
    "project": "pulsar",
    "entity": "",
    "run_name": "",
    "group": "lfpo",
    "job_type": "offline_pretrain",
    "dir": "",
    "mode": "online",
    "python_executable": "python3",
    "script_path": "scripts/wandb_stream.py",
    "tags": ["offline", "lfpo", "future_evaluator", "continuum"]
  }
}
