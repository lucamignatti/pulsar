{
  "schema_version": 1,
  "obs_schema_version": 1,
  "env": {
    "mode": "soccar",
    "collision_meshes_path": "collision_meshes",
    "team_size": 2,
    "tick_skip": 8,
    "tick_rate": 120,
    "max_episode_ticks": 2250,
    "no_touch_timeout_seconds": 10.0,
    "spawn_opponents": true,
    "randomize_kickoffs": true,
    "seed": 7
  },
  "reward": {
    "ngp_checkpoint": "",
    "ngp_scale": 1.0,
    "touch_reward": 0.02,
    "goal_reward": 1.0,
    "concede_penalty": 1.0,
    "online_dataset": {
      "enabled": true,
      "output_dir": "",
      "shard_size": 65536,
      "train_fraction": 0.95,
      "seed": 7
    },
    "refresh": {
      "enabled": true,
      "candidate_checkpoint": "",
      "check_interval_updates": 4,
      "train_candidate_in_process": true,
      "online_train_fraction": 0.7,
      "anchor_train_manifest": "data/offline/2v2/train_manifest.json",
      "anchor_val_manifest": "data/offline/2v2/val_manifest.json",
      "candidate_epochs": 1,
      "old_data_fraction": 0.3,
      "min_online_train_samples": 32768,
      "min_recent_loss_improvement": 0.02,
      "max_anchor_loss_regression": 0.01,
      "promotion_cooldown_updates": 4,
      "train_trunk": false,
      "max_online_windows": 4,
      "max_online_samples": 0,
      "async_candidate_updates": true,
      "max_ngp_versions": 10,
      "max_ngp_runtime_summaries": 100
    }
  },
  "action_table": {
    "builtin": "rlgym_lookup_v1",
    "actions": []
  },
  "model": {
    "observation_dim": 132,
    "action_dim": 90,
    "use_layer_norm": true,
    "encoder_dim": 512,
    "workspace_dim": 512,
    "stm_slots": 48,
    "stm_key_dim": 128,
    "stm_value_dim": 128,
    "ltm_slots": 32,
    "ltm_dim": 128,
    "controller_dim": 512,
    "consolidation_stride": 8,
    "retired_decay": 0.96
  },
  "ppo": {
    "num_envs": 256,
    "collection_workers": 0,
    "init_checkpoint": "",
    "rollout_length": 256,
    "minibatch_size": 32768,
    "epochs": 3,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_range": 0.2,
    "entropy_coef": 0.01,
    "value_coef": 1.0,
    "learning_rate": 0.0002,
    "max_grad_norm": 1.0,
    "device": "cuda",
    "checkpoint_interval": 10,
    "sequence_length": 16,
    "burn_in": 0,
    "value_v_min": -10.0,
    "value_v_max": 10.0,
    "value_num_atoms": 51,
    "use_adaptive_epsilon": true,
    "adaptive_epsilon_beta": 1.0,
    "epsilon_min": 0.05,
    "epsilon_max": 0.3,
    "use_confidence_weighting": true,
    "confidence_weight_type": "entropy",
    "confidence_weight_delta": 1e-06,
    "normalize_confidence_weights": false,
    "self_play": {
      "enabled": true,
      "opponent_probability": 0.5,
      "snapshot_interval_updates": 10,
      "max_snapshots": 8,
      "training_opponent_policy": "stochastic",
      "eval_interval_updates": 10,
      "eval_num_envs": 8,
      "eval_matches_per_snapshot": 4,
      "eval_policy": "deterministic",
      "elo_initial": 1000.0,
      "elo_k": 32.0
    }
  },
  "wandb": {
    "enabled": false,
    "project": "pulsar",
    "entity": "",
    "run_name": "",
    "group": "ppo",
    "job_type": "ppo_train",
    "dir": "",
    "mode": "online",
    "python_executable": "python3",
    "script_path": "scripts/wandb_stream.py",
    "tags": ["ppo", "continuum", "dppo"]
  }
}
